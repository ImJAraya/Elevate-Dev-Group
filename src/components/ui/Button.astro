---
interface Props {
  href: string;
  variant?: 'primary' | 'ghost';
  label: string;
  newTab?: boolean;
}

const { href, variant = 'primary', label, newTab = false } = Astro.props;

const classes =
  variant === 'primary'
    ? 'btn btn-primary'
    : 'btn btn-ghost';
---

<a
  class={classes}
  href={href}
  target={newTab ? '_blank' : undefined}
  rel={newTab ? 'noopener noreferrer' : undefined}
>
  {label}
</a>
