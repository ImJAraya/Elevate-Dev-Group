---
import Button from '../ui/Button.astro';
import SectionHeader from '../ui/SectionHeader.astro';
import { siteConfig } from '../../content/site';

const { contact } = siteConfig;
const whatsappHref = `https://wa.me/${contact.whatsappNumber}?text=${encodeURIComponent(contact.whatsappPresetMessage)}`;
---

<section id="contacto" class="section">
  <SectionHeader
    eyebrow="Contacto"
    title="Cuéntanos tu proyecto"
    description="Comparte tu idea y te enviaremos una propuesta alineada a objetivos, tiempos y alcance técnico."
  />

  <div class="contact-grid">
    <form
      name="contact"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="contact-form reveal"
    >
      <input type="hidden" name="form-name" value="contact" />
      <p hidden>
        <label>
          No llenar: <input name="bot-field" />
        </label>
      </p>

      <label>
        Nombre
        <input name="name" type="text" required minlength="2" placeholder="Tu nombre" />
      </label>

      <label>
        Email
        <input name="email" type="email" required placeholder="tu@email.com" />
      </label>

      <label>
        Tipo de proyecto
        <select name="projectType" required>
          <option value="" selected disabled>Selecciona una opción</option>
          <option value="landing">Landing page</option>
          <option value="web-app">Web app</option>
          <option value="desktop-app">Desktop app</option>
          <option value="otro">Otro</option>
        </select>
      </label>

      <label>
        Mensaje
        <textarea
          name="message"
          required
          minlength="20"
          rows="5"
          placeholder="Describe brevemente tu objetivo, alcance o problema actual."
        ></textarea>
      </label>

      <button class="btn btn-primary" type="submit">Enviar solicitud</button>
    </form>

    <aside class="contact-aside reveal delay-1">
      <h3>Respuesta comercial</h3>
      <p>{contact.responseTime}</p>
      <p>
        También puedes escribirnos a
        <a href={`mailto:${contact.email}`}>{contact.email}</a>
      </p>
      <Button href={whatsappHref} label="Hablar por WhatsApp" variant="ghost" newTab />
    </aside>
  </div>
</section>
